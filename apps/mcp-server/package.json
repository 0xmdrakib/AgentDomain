{
  "name": "@agentdomain/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing AgentDomain registration & management tools to any LLM",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agentdomain-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
