  },
  "dependencies": {
    "@agentdomain/sdk": "workspace:*",
    "@agentdomain/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "viem": "^2.21.55",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
