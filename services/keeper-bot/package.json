{
  "name": "@agentdomain/keeper-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Keeper bot that triggers autonomous renewals on the RenewalVault contract",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "tick": "tsx src/cli/tick.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint\""
  },
  "dependencies": {
    "@agentdomain/storage": "workspace:*",
    "@aws-sdk/client-dynamodb": "^3.812.0",
    "@aws-sdk/lib-dynamodb": "^3.812.0",
    "@agentdomain/shared": "workspace:*",
    "viem": "^2.21.55",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
