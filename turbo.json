{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["apps/web/.env.local"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_CHAIN_ID",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID",
    "DATABASE_URL",
    "REDIS_URL",
    "BASE_RPC_URL",
    "BASE_SEPOLIA_RPC_URL",
    "BASE_CHAIN_ID",
    "ETHEREUM_RPC_URL",
    "PAYMENT_ROUTER_ADDRESS",
    "IDENTITY_REGISTRY_ADDRESS",
    "RENEWAL_VAULT_ADDRESS",
    "USDC_ADDRESS",
    "TREASURY_ADDRESS",
    "BACKEND_PRIVATE_KEY",
    "X402_FACILITATOR_URL",
    "X402_NETWORK",
    "LIFI_API_URL",
    "LIFI_API_KEY",
    "LIFI_INTEGRATOR",
    "LIFI_REFERRER",
    "LIFI_SLIPPAGE",
    "LIFI_MAX_WAIT_SECONDS",
    "SPACESHIP_API_KEY",
    "SPACESHIP_API_SECRET",
    "SPACESHIP_CONTACT_FIRST_NAME",
    "SPACESHIP_CONTACT_LAST_NAME",
    "SPACESHIP_CONTACT_EMAIL",
    "SPACESHIP_CONTACT_PHONE",
    "SPACESHIP_CONTACT_ADDRESS",
    "SPACESHIP_CONTACT_CITY",
    "SPACESHIP_CONTACT_STATE",
    "SPACESHIP_CONTACT_POSTAL_CODE",
    "SPACESHIP_CONTACT_COUNTRY",
    "SPACESHIP_CONTACT_ORGANIZATION",
    "SPACESHIP_DEFAULT_CONTACT_ID",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ACCOUNT_ID",
    "ACME_ACCOUNT_PRIVATE_KEY",
    "ACME_CONTACT_EMAIL",
    "ACME_DIRECTORY_URL",
    "ACME_PREFERRED_CHAIN",
    "SSL_CERT_ENCRYPTION_KEY",
    "SSL_RENEW_BEFORE_DAYS",
    "SSL_DNS_PROPAGATION_SECONDS",
    "SSL_PROVISIONER_BATCH_SIZE",
    "SSL_PROVISIONER_TICK_INTERVAL_SECONDS",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "TURNSTILE_SECRET_KEY",
    "TURNSTILE_REQUIRED",
    "ADMIN_ADDRESSES",
    "CRON_SECRET",
    "RESEND_API_KEY",
    "RESEND_WEBHOOK_SECRET",
    "PINATA_JWT",
    "SENTRY_DSN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
